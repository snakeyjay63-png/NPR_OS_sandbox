{
  "name": "npr-local",
  "version": "0.0.2",
  "description": "NPR Local — single-agent, local-only runtime",
  "main": "src/index.js",
  "bin": {
    "npr": "./bin/npr.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node test-stack.js",
    "verify:encoding": "python3 verify_encoding.py .",
    "fix:encoding": "python3 verify_encoding.py . --fix",
    "tmux": "bash scripts/npr-tmux.sh",
    "tmux:detach": "bash scripts/npr-tmux.sh detach"
  },
  "dependencies": {
    "epoll": "^4.0.2"
  }
}
